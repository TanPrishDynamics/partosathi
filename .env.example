# ═══════════════════════════════════════════════════════════════════════════════
# e-Partogram — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# USAGE:
#   cp .env.example .env
#   Fill in real values — NEVER commit .env to git.
#
# Generate strong secrets:
#   JWT_SECRET_KEY / SECRET_KEY:
#     python3 -c "import secrets; print(secrets.token_hex(32))"
#   FIELD_ENCRYPTION_KEY (Fernet — REQUIRED in every environment):
#     python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   SEED_ADMIN_PASSWORD (initial admin / demo doctor):
#     python3 -c "import secrets; print(secrets.token_urlsafe(24))"
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────────────────
# C-4: Default is "production" — opt-in to "development" or "testing".
# A deployment that omits this variable runs in production mode with all
# security guards active.
FLASK_ENV=development

# ── Security secrets (REQUIRED) ───────────────────────────────────────────────
# All four are mandatory — the app refuses to start without them.
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX
SECRET_KEY=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_HEX

# C-3: FIELD_ENCRYPTION_KEY is required in EVERY environment (dev/test/prod).
# Protects Patient.name and other PHI columns at rest. The app fails fast at
# import time if this is missing or short — there is no silent plaintext fallback.
FIELD_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Seed password for the demo admin/doctor accounts. Must NOT be one of the
# known-weak defaults in production.
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_RANDOM_VALUE

# ── Demo data (H-6) ───────────────────────────────────────────────────────────
# Set to "1" to seed demo accounts on startup. Production refuses to seed
# regardless of this flag.
SEED_DEMO_DATA=0

# ── Token expiry ──────────────────────────────────────────────────────────────
ACCESS_TOKEN_MINUTES=15        # short-lived access token (15 min recommended)
REFRESH_TOKEN_DAYS=7           # HttpOnly refresh token rotation window
IDLE_TIMEOUT_MINUTES=30        # client-side idle auto-logout window (L-6)

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5001
VITE_ADMIN_PORTAL_URL=http://localhost:5175  # M-20 — env-driven admin SPA URL

# ── CORS (JSON array of allowed origins) ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:5175"]
# Production example: ["https://your-domain.com","https://admin.your-domain.com"]

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///partogram.db
# Production (PostgreSQL via docker-compose):
# DATABASE_URL=postgresql://partogram:REPLACE_PG_PASSWORD@database:5432/partogram
POSTGRES_USER=partogram
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=partogram

# ── Rate limiting (H-1: Redis MANDATORY in production) ────────────────────────
# Memory backend is dev/test only — production startup is refused if memory://.
RATELIMIT_STORAGE_URI=memory://
# Production:
# RATELIMIT_STORAGE_URI=redis://redis:6379/0

# ── Email (approval/rejection notifications) ──────────────────────────────────
SMTP_USERNAME=REPLACE_WITH_SENDER_EMAIL
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD   # Gmail App Password, not account pw
SMTP_FROM_NAME=e-Partogram Admin
ADMIN_NOTIFY_EMAIL=admin@your-domain.com

# ── ML / AI ───────────────────────────────────────────────────────────────────
# C-2: Leaving GOOGLE_API_KEY unset disables the LLM clinical summary path.
# The deterministic rule-based summary remains fully functional and is the
# recommended setting until a Google Cloud BAA + Vertex AI region is in place.
GOOGLE_API_KEY=
ML_MODEL_PATH=./ml/lstm_model.pth
LLM_TIMEOUT_SECONDS=8

# ── Cloud secrets manager (C-1, optional) ─────────────────────────────────────
# Configure ONE of the following to source secrets from a managed vault at
# boot. Local .env values are never overwritten — vault values are injected
# only for keys not already in the environment.
#
# AWS Secrets Manager:
# AWS_SECRETS_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:e-partogram-XXXX
# AWS_REGION=us-east-1
#
# HashiCorp Vault (KV-v2):
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=hvs....
# VAULT_PATH=secret/data/e-partogram
# VAULT_MOUNT=secret
#
# GCP Secret Manager:
# GCP_SECRET_NAME=projects/my-project/secrets/e-partogram/versions/latest

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
