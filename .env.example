# ═══════════════════════════════════════════════════════════════════════════════
# e-Partogram — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
# USAGE:
#   cp .env.example .env
#   Fill in real values — NEVER commit .env to git
#
# Generate JWT secret:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment ───────────────────────────────────────────────────────────────
FLASK_ENV=development          # 'development' | 'production'
                               # ⚠️  MUST be 'production' on server

# ── Security (CRITICAL — app refuses to start if missing in production) ───────
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
# Example: 3f8a2b1c9d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a

SECRET_KEY=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5001

# ── CORS (JSON array of allowed origins) ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:5174"]
# Production: ["https://your-domain.com"]

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development — default)
DATABASE_URL=sqlite:///partogram.db

# MySQL (production — run database/migrate.py first)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/partogram?charset=utf8mb4
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MYSQL_DB=partogram

# ── Rate Limiting (production: use Redis for multi-process support) ────────────
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ── ML / AI ───────────────────────────────────────────────────────────────────
ML_MODEL_PATH=./backend/ml/lstm_model.pth

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5001
